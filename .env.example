# Serverseitige Zustellung der Formular-Anfragen (Anfrage und Kontakt).
# Ohne diese Werte funktioniert das Formular weiterhin und öffnet als Fallback
# das E-Mail-Programm des Besuchers (mailto an office@magotransport.at).

# API-Schlüssel von https://resend.com (kostenloses Kontingent verfügbar)
RESEND_API_KEY=

# Absenderadresse einer bei Resend verifizierten Domain, z. B.
# "MAGOTransport <anfrage@magotransport.at>"
# Schnelltest ohne eigene Domain: onboarding@resend.dev
INQUIRY_FROM_EMAIL=

# Empfänger der Anfragen. Optional, Standard: office@magotransport.at
# Hinweis: Beim Schnelltest mit onboarding@resend.dev liefert Resend nur an
# die E-Mail-Adresse des eigenen Resend-Kontos aus.
INQUIRY_TO_EMAIL=office@magotransport.at
